{
  "buildCommand": "npm run build",
  "framework": "vite",
  "outputDirectory": "dist",
  "routes": [
    {
      "src": "^/assets/.*",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "^/icons/.*",
      "headers": {
        "cache-control": "public, max-age=86400"
      }
    },
    {
      "src": "^/.*\\.(json|xml|png|jpg|jpeg|gif|svg)$",
      "headers": {
        "cache-control": "public, max-age=86400"
      }
    },
    {
      "src": "^/(?!.*\\.).*$",
      "dest": "/index.html",
      "status": 200
    }
  ]
}
